module testbench;

 // tb signals
 reg OVR;
 reg clk;
 reg rst_n;

 wire out;
 wire [1:0] state;
 wire [3:0] timer;

 // instantiate DUT
 fsm_timer_demo dut(
   .out(out),
   .state(state),
   .timer(timer),
   .OVR(OVR),
   .clk(clk),
   .rst_n(rst_n)
 );

 // clock generation
 initial clk = 1'b0;
 always #5 clk = ~clk;

 // stimulus
 initial begin
   OVR   = 1'b0;
   rst_n = 1'b0;

   repeat(3) @(negedge clk);
   rst_n = 1'b1;

   // Run through:
   // S0 for 3 counts
   // S1 for 4 counts
   // S2 for 3 counts
   repeat(12) @(negedge clk);

   // Force exit from S3 (if reached)
   OVR = 1'b1;
   repeat(2) @(negedge clk);
   OVR = 1'b0;

   repeat(5) @(negedge clk);
 end

endmodule